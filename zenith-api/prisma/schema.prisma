// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// ─────────────────────────────────────────────────────────────────────────────
// GENERATORS
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

// ─────────────────────────────────────────────────────────────────────────────
// DATASOURCE
// ─────────────────────────────────────────────────────────────────────────────

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────────────────

enum UserRole {
  READER
  EDITOR
  ADMIN
}

enum SuggestionStatus {
  PENDING
  APPLIED
  REJECTED
  SUPERSEDED
}

// ─────────────────────────────────────────────────────────────────────────────
// SCRAPER DOMAIN — Content (owned by zenith-scrapper, read-only for API)
// ─────────────────────────────────────────────────────────────────────────────

model Author {
  id          Int      @id @default(autoincrement())
  name        String   @unique @db.VarChar(255)
  description String?  @db.Text
  novels      Novel[]
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("authors")
}

model Genre {
  id          Int            @id @default(autoincrement())
  name        String         @unique @db.VarChar(255)
  description String?        @db.Text
  novels      NovelToGenre[]
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  @@map("genres")
}

model NovelToGenre {
  novelId Int @map("novel_id")
  genreId Int @map("genre_id")

  novel Novel @relation(fields: [novelId], references: [id], onDelete: Cascade)
  genre Genre @relation(fields: [genreId], references: [id], onDelete: Cascade)

  @@id([novelId, genreId])
  @@index([novelId])
  @@index([genreId])
  @@map("novel_genres")
}

model Novel {
  id          Int            @id @default(autoincrement())
  title       String         @db.VarChar(255)
  slug        String         @unique @db.VarChar(255) @map("slug")
  url         String         @unique @db.VarChar(255)
  coverUrl    String?        @db.VarChar(512) @map("cover_url")
  description String?        @db.Text
  status      String?        @db.VarChar(50)
  language    String         @default("en") @db.VarChar(10) @map("language")
  reads       Int            @default(0) @map("reads")
  author      Author?        @relation(fields: [authorId], references: [id], onDelete: SetNull)
  authorId    Int?           @map("author_id")
  genres      NovelToGenre[]
  chapters    Chapter[]
  suggestions Suggestion[]
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")
  modifiedBy  String?        @db.VarChar(255) @map("modified_by")

  @@index([authorId])
  @@map("novels")
}

model Chapter {
  id          Int          @id @default(autoincrement())
  title       String       @db.VarChar(255)
  url         String       @db.VarChar(255)
  content     String?      @db.LongText
  orderIndex  Int          @map("order_index")
  language    String       @default("en") @db.VarChar(10) @map("language")
  reads       Int          @default(0) @map("reads")
  novel       Novel        @relation(fields: [novelId], references: [id], onDelete: Cascade)
  novelId     Int          @map("novel_id")
  suggestions Suggestion[]
  corrections Correction[]
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  modifiedBy  String?      @db.VarChar(255) @map("modified_by")

  @@unique([novelId, orderIndex])
  @@index([novelId])
  @@index([url])
  @@map("chapters")
}

// ─────────────────────────────────────────────────────────────────────────────
// USER DOMAIN — Auth (owned by zenith-api)
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id           Int          @id @default(autoincrement())
  email        String       @unique @db.VarChar(255)
  username     String       @unique @db.VarChar(100) @map("username")
  passwordHash String       @db.VarChar(255) @map("password_hash")
  role         UserRole     @default(READER) @map("role")
  suggestions  Suggestion[]
  votes        Vote[]
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  @@map("users")
}

// ─────────────────────────────────────────────────────────────────────────────
// EDITORIAL DOMAIN — Suggestions, Votes, Corrections (owned by zenith-api)
// ─────────────────────────────────────────────────────────────────────────────

model Suggestion {
  id             Int              @id @default(autoincrement())
  chapterId      Int              @map("chapter_id")
  novelId        Int              @map("novel_id")
  userId         Int              @map("user_id")
  paragraphIndex Int              @map("paragraph_index")
  originalText   String           @db.Text @map("original_text")
  proposedText   String           @db.Text @map("proposed_text")
  note           String?          @db.VarChar(500) @map("note")
  status         SuggestionStatus @default(PENDING) @map("status")
  voteCount      Int              @default(0) @map("vote_count")
  chapter        Chapter          @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  novel          Novel            @relation(fields: [novelId], references: [id], onDelete: Cascade)
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  votes          Vote[]
  correction     Correction?
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  @@index([chapterId, paragraphIndex])
  @@index([chapterId, status])
  @@index([userId])
  @@map("suggestions")
}

model Vote {
  id           Int        @id @default(autoincrement())
  suggestionId Int        @map("suggestion_id")
  userId       Int        @map("user_id")
  suggestion   Suggestion @relation(fields: [suggestionId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now()) @map("created_at")

  @@unique([suggestionId, userId])
  @@map("votes")
}

model Correction {
  id             Int        @id @default(autoincrement())
  chapterId      Int        @map("chapter_id")
  paragraphIndex Int        @map("paragraph_index")
  suggestionId   Int        @unique @map("suggestion_id")
  chapter        Chapter    @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  suggestion     Suggestion @relation(fields: [suggestionId], references: [id], onDelete: Cascade)
  appliedAt      DateTime   @default(now()) @map("applied_at")

  @@unique([chapterId, paragraphIndex])
  @@map("corrections")
}
